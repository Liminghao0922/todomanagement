# 开发环境配置 - 请在 Azure Portal 中获取这些值并替换：
# 步骤：https://portal.azure.com → Microsoft Entra ID → App registrations → New registration
# Application (client) ID：从应用注册详情页面复制
VITE_AZURE_CLIENT_ID=4f56fade-af2b-4456-9dc6-c110d0776f35

# Directory (tenant) ID：从应用注册详情页面复制
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/f335f8bf-b5a9-466f-806a-d14b03f7ae76

# 重定向 URI：必须与 Azure Portal 中配置的 SPA 重定向 URI 匹配
VITE_AZURE_REDIRECT_URI=http://localhost:5173

VITE_API_BASE_URL=http://localhost:7071/api